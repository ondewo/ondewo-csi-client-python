# ---------------------------------------------------------------------------
# ONDEWO CSI Python client SDK - examples configuration (TEMPLATE).
#
# This is a non-secret template. Copy it, fill in real values locally and keep
# secrets out of version control. Every example under examples/ loads this file
# via python-dotenv (load_dotenv(Path(__file__).with_name("environment.env"))).
#
# Variable names follow the ONE canonical scheme shared across all ONDEWO SDK
# examples: one name per concept (never HOST vs HOSTNAME vs grpcHost drift).
# ---------------------------------------------------------------------------

# --- Connection (CSI gRPC endpoint) ----------------------------------------
ONDEWO_HOST=localhost
ONDEWO_PORT=50055

# --- Secure channel --------------------------------------------------------
# ONDEWO_USE_SECURE_CHANNEL: "true" to open a TLS gRPC channel, "false" for plaintext.
ONDEWO_USE_SECURE_CHANNEL=false
# ONDEWO_GRPC_CERT: optional path to a PEM certificate file for the secure channel.
ONDEWO_GRPC_CERT=

# --- Keycloak headless (ROPC / bearer) authentication ----------------------
KEYCLOAK_URL=https://keycloak.ondewo.com/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
KEYCLOAK_USER_NAME=tech-user@ondewo.com
KEYCLOAK_PASSWORD=
# KEYCLOAK_VERIFY_SSL: "false" only for a self-signed/local Keycloak (e.g. Envoy on localhost).
KEYCLOAK_VERIFY_SSL=true

# --- SIP connection (only used by speech2speech_with_hangup_example.py) -----
ONDEWO_SIP_HOST=localhost
ONDEWO_SIP_PORT=50053

# --- CSI service-specific --------------------------------------------------
# S2S (speech-to-speech) pipeline to stream against.
ONDEWO_CSI_S2S_PIPELINE_ID=pizza
# S2S pipeline used by the hang-up example (drives a SIP HANGUP trigger).
ONDEWO_CSI_S2S_HANGUP_PIPELINE_ID=hangup
# Path to the WAV file streamed by s2s_streaming_example.py.
ONDEWO_CSI_S2S_AUDIO_FILE=examples/audiofiles/pizza_de.wav
# Base filename (without extension) converted from .raw to .wav by convert_files.py.
ONDEWO_CSI_CONVERT_FILE=test
